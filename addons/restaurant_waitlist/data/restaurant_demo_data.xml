<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="journal_pos_sale_restaurant" model="account.journal">
        <field name="name">Punto de Venta Restaurante</field>
        <field name="code">POSS</field>
        <field name="type">general</field>
        <field name="company_id" ref="base.main_company"/>
    </record>

    <record id="journal_cash_restaurant" model="account.journal">
        <field name="name">Efectivo Restaurante</field>
        <field name="code">CSHR</field>
        <field name="type">cash</field>
        <field name="company_id" ref="base.main_company"/>
    </record>

    <record id="journal_bank_restaurant" model="account.journal">
        <field name="name">Banco Restaurante</field>
        <field name="code">BNKR</field>
        <field name="type">bank</field>
        <field name="company_id" ref="base.main_company"/>
    </record>

    <record id="payment_cash_restaurant" model="pos.payment.method">
        <field name="name">Efectivo</field>
        <field name="journal_id" ref="journal_cash_restaurant"/>
        <field name="company_id" ref="base.main_company"/>
    </record>

    <record id="payment_card_restaurant" model="pos.payment.method">
        <field name="name">Tarjeta</field>
        <field name="journal_id" ref="journal_bank_restaurant"/>
        <field name="company_id" ref="base.main_company"/>
    </record>

    <record id="payment_customer_account_restaurant" model="pos.payment.method">
        <field name="name">Cuenta de cliente</field>
        <field name="split_transactions">True</field>
        <field name="company_id" ref="base.main_company"/>
    </record>

    <record id="floor_main_dining_room" model="restaurant.floor">
        <field name="name">Main Floor</field>
        <field name="sequence">1</field>
        <field name="background_color">rgb(237,230,219)</field>
        <field name="active">True</field>
    </record>

    <record id="floor_patio" model="restaurant.floor">
        <field name="name">Patio</field>
        <field name="sequence">2</field>
        <field name="background_color">rgb(222,236,225)</field>
        <field name="active">True</field>
    </record>

    <record id="pos_config_restaurante_augusto" model="pos.config">
        <field name="name">Restaurante Augusto</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="journal_id" ref="journal_pos_sale_restaurant"/>
        <field name="payment_method_ids" eval="[(6, 0, [ref('payment_cash_restaurant'), ref('payment_card_restaurant'), ref('payment_customer_account_restaurant')])]"/>
        <field name="module_pos_restaurant">True</field>
        <field name="iface_splitbill">True</field>
        <field name="floor_ids" eval="[(6, 0, [ref('floor_main_dining_room'), ref('floor_patio')])]"/>
    </record>

    <record id="table_main_01" model="restaurant.table">
        <field name="floor_id" ref="floor_main_dining_room"/>
        <field name="table_number">1</field>
        <field name="identifier">1</field>
        <field name="seats">4</field>
        <field name="position_h">220</field>
        <field name="position_v">120</field>
