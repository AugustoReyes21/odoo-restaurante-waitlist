<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_restaurant_waitlist_list" model="ir.ui.view">
        <field name="name">restaurant.waitlist.list</field>
        <field name="model">restaurant.waitlist</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'notified'" decoration-success="state == 'seated'" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="check_in_datetime"/>
                <field name="customer_name"/>
                <field name="phone"/>
                <field name="party_size"/>
                <field name="estimated_wait_minutes"/>
                <field name="priority"/>
                <field name="pos_config_id"/>
                <field name="table_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_restaurant_waitlist_form" model="ir.ui.view">
        <field name="name">restaurant.waitlist.form</field>
        <field name="model">restaurant.waitlist</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_notify" type="object" string="Avisar" invisible="state not in ['waiting']"/>
                    <button name="action_seat" type="object" string="Sentar cliente" invisible="state not in ['waiting', 'notified']"/>
                    <button name="action_reset_waiting" type="object" string="Regresar a espera" invisible="state == 'waiting'"/>
                    <button name="action_cancel" type="object" string="Cancelar" invisible="state == 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="waiting,notified,seated,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="customer_id"/>
                            <field name="customer_name"/>
                            <field name="phone"/>
                            <field name="party_size"/>
                        </group>
                        <group>
                            <field name="check_in_datetime"/>
                            <field name="estimated_wait_minutes"/>
                            <field name="priority"/>
                            <field name="pos_config_id"/>
                            <field name="table_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_restaurant_waitlist_search" model="ir.ui.view">
        <field name="name">restaurant.waitlist.search</field>
        <field name="model">restaurant.waitlist</field>
        <field name="arch" type="xml">
            <search>
                <field name="customer_name"/>
                <field name="phone"/>
                <field name="pos_config_id"/>
                <field name="table_id"/>
                <filter name="waiting" string="En espera" domain="[('state', '=', 'waiting')]"/>
                <filter name="notified" string="Avisado" domain="[('state', '=', 'notified')]"/>
                <filter name="seated" string="Sentado" domain="[('state', '=', 'seated')]"/>
                <separator/>
                <filter name="group_state" string="Agrupar por estado" context="{'group_by': 'state'}"/>
                <filter name="group_restaurant" string="Agrupar por restaurante" context="{'group_by': 'pos_config_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_restaurant_waitlist" model="ir.actions.act_window">
        <field name="name">Lista de Espera</field>
        <field name="res_model">restaurant.waitlist</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_waiting': 1}</field>
    </record>
</odoo>
